# Servidor Backend — fijo a interfaz eno1
API_PORT=5000
API_HOST=192.168.0.106

# SSL — rutas relativas a la raíz del proyecto
SSL_CERT_PATH=ssl/ltesistem.crt
SSL_KEY_PATH=ssl/ltesistem.key

# Base de datos PostgreSQL
DB_USER=postgres
DB_PASSWORD=admin123
DB_NAME=db
DB_HOST=localhost
DB_PORT=5432

# Prisma
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

JWT_SECRET=your-super-secure-jwt-secret-here

FRONTEND_ORIGINS=https://192.168.0.106:4000,https://localhost:4000,https://ltesistem.local:4000
