generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum Role {
  ADMIN
  OPERATOR
}

enum DeviceType {
  FIXED
  MOBILE
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  ALERT
}

//////////////////////////////////////////////////
// MODELOS
//////////////////////////////////////////////////

model User {
  id       String @id @default(uuid())
  name     String
  username String @unique
  password String
  role     Role   @default(OPERATOR)

  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  geoLocation GeoUser? @relation("GeoUserAccount")

  createdAt DateTime @default(now())
}

model Device {
  id               String   @id @default(cuid())
  deviceId         String   @unique @map("device_id") @db.VarChar(50) // Hardware ID: "ESP32-XXXX"
  displayName      String   @map("display_name") @db.VarChar(255)
  ipAddress        String?  @map("ip_address") @db.VarChar(100)
  networkType      String   @default("wifi") @map("network_type") @db.VarChar(20) // "wifi" | "lte"
  hasGps           Boolean  @default(false) @map("has_gps")
  latitude         Decimal  @default(11.019464) @db.Decimal(10, 8)
  longitude        Decimal  @default(-74.851522) @db.Decimal(11, 8)
  status           String   @default("ACTIVE") // ACTIVE, INACTIVE, ALERT
  samplingInterval Int      @default(5) @map("sampling_interval") // segundos
  sensors          Json? // Definición estricta de sensores programada en firmware
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([deviceId])
  @@index([status])
  @@index([updatedAt])
}

model Message {
  id      String @id @default(uuid())
  content String

  senderId String
  sender   User   @relation("SentMessages", fields: [senderId], references: [id])

  receiverId String
  receiver   User   @relation("ReceivedMessages", fields: [receiverId], references: [id])

  createdAt DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

//////////////////////////////////////////////////
// GEO TRACKING MODULE
//////////////////////////////////////////////////

model GeoUser {
  id         String   @id @default(uuid())
  accountId  String   @unique @map("account_id")
  latitude   Decimal  @db.Decimal(10, 8)
  longitude  Decimal  @db.Decimal(11, 8)
  online     Boolean  @default(true)
  lastUpdate DateTime @default(now()) @map("last_update")
  createdAt  DateTime @default(now()) @map("created_at")

  account User @relation("GeoUserAccount", fields: [accountId], references: [id], onDelete: Cascade)

  @@index([online])
  @@index([lastUpdate])
  @@map("geo_users")
}

model GeoDevice {
  id               String    @id @default(uuid())
  deviceId         String    @unique @map("device_id") @db.VarChar(50) // Hardware ID: "ESP32-XXXX"
  name             String    @db.VarChar(255)
  description      String?   @db.VarChar(500)
  type             String    @db.VarChar(50) // "temperature", "motion", "humidity", etc.
  networkType      String    @default("wifi") @map("network_type") @db.VarChar(20) // "wifi" | "lte"
  latitude         Decimal   @db.Decimal(10, 8)
  longitude        Decimal   @db.Decimal(11, 8)
  hasGps           Boolean   @default(false) @map("has_gps")
  online           Boolean   @default(false)
  sensorData       Json?     @map("sensor_data") // Latest sensor readings
  sensorConfig     Json?     @map("sensor_config") // Pin assignments & sensor types
  samplingInterval Int       @default(5) @map("sampling_interval") // seconds
  programmedBy     String?   @map("programmed_by") @db.VarChar(255)
  programmedAt     DateTime? @map("programmed_at")
  lastUpdate       DateTime  @default(now()) @map("last_update")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([deviceId])
  @@index([type])
  @@index([online])
  @@index([lastUpdate])
  @@map("geo_devices")
}
